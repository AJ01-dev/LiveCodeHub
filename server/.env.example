# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Option A: Local Docker — run `docker compose up -d` from project root
# MONGODB_URI=mongodb://localhost:27017/codecollab
# Option B: MongoDB Atlas — see docs/MONGODB_SETUP.md
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/codecollab?retryWrites=true&w=majority
# Option C: In-memory MongoDB (dev only, no install needed)
USE_MEMORY_DB=true
MONGODB_URI=mongodb://localhost:27017/codecollab

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Judge0 API
# Option A: Free public Judge0 CE (no API key required, good for development)
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_API_KEY=
JUDGE0_API_HOST=
# Option B: RapidAPI (higher limits for production) — see docs/JUDGE0_SETUP.md
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key_here
# JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
