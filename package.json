{
  "name": "codecollab",
  "version": "1.0.0",
  "description": "CodeCollab - Real-time collaborative coding platform",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev:server": "npm run dev --prefix server",
